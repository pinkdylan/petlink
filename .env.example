# 宠相随 (PetLink) 环境变量示例
# 使用方式：复制本文件为 .env.local 并填入真实值，勿将 .env.local 提交到 Git

# 数据库（Prisma）
# 本地开发推荐 Docker 跑 Postgres，连接 localhost:5432；MVP 跑通后再选部署方案（Vercel+托管 DB 或 VPS+Docker）
# PostgreSQL 示例：
DATABASE_URL="postgresql://user:password@localhost:5432/petlink?schema=public"
# SQLite MVP 示例：
# DATABASE_URL="file:./dev.db"

# AI 问诊（OpenAI / DeepSeek 等）
AI_API_KEY=""
AI_BASE_URL=""
# AI_MODEL 可选，默认 gpt-4o-mini；DeepSeek 可用 deepseek-chat
# AI_MODEL="deepseek-chat"

# 可选：V1.5 视频存证 OSS
# OSS_REGION=""
# OSS_BUCKET=""
# OSS_ACCESS_KEY=""
# OSS_SECRET_KEY=""
